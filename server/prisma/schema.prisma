generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Account {
  id           String          @id @default(uuid())
  login        String          @unique
  passwordHash String
  refreshToken String          @default("")
  progress     PlayerProgress? 
}

model PlayerProgress {
  id              String  @id @default(uuid())
  accountId       String  @unique
  account         Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  metaGold        Int     @default(0)
  unlockedClasses String  @default("warrior")
  unlockedWeapons String  @default("wpn_iron_sword")
}

model RunSave {
  id          String            @id @default(uuid())
  sessionId   String            @unique
  hostLogin   String
  floorNumber Int               @default(1)
  roomWidth   Int               @default(800)
  roomHeight  Int               @default(600)
  players     PlayerSaveState[]
  createdAt   DateTime          @default(now())
}

model PlayerSaveState {
  id             String  @id @default(uuid())
  runSaveId      String
  runSave        RunSave @relation(fields: [runSaveId], references: [id], onDelete: Cascade)
  login          String
  archetype      String
  hp             Int
  maxHp          Int
  mana           Float
  maxMana        Int
  gold           Int
  weaponPresetId String
  inventory      String  @default("")
}