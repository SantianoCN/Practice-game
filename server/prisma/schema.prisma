generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Account {
  id           String          @id @default(uuid())
  login        String          @unique
  passwordHash String
  refreshToken String          @default("")
  progress     PlayerProgress? // Связь один-к-одному с таблицей прогресса
}

model PlayerProgress {
  id              String  @id @default(uuid())
  accountId       String  @unique
  account         Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  metaGold        Int     @default(0) // Мета-золото между забегами
  unlockedClasses String  @default("warrior") // Храним через запятую: "warrior"
  unlockedWeapons String  @default("wpn_iron_sword") // Храним через запятую: "wpn_iron_sword"
}