generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Account {
  id           String          @id @default(uuid())
  login        String          @unique
  passwordHash String
  refreshToken String          @default("")
  progress     PlayerProgress?
}

model PlayerProgress {
  id              String           @id @default(uuid())
  accountId       String           @unique
  account         Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  gold            Int              @default(0)
  unlockedClasses UnlockedClass[]
  unlockedWeapons UnlockedWeapon[]
}

model UnlockedClass {
  id               String         @id @default(uuid())
  playerProgressId String
  playerProgress   PlayerProgress @relation(fields: [playerProgressId], references: [id], onDelete: Cascade)
  classId          String
  @@unique([playerProgressId, classId])
}

model UnlockedWeapon {
  id               String         @id @default(uuid())
  playerProgressId String
  playerProgress   PlayerProgress @relation(fields: [playerProgressId], references: [id], onDelete: Cascade)
  weaponId         String
  @@unique([playerProgressId, weaponId])
}

model RunSave {
  id          String            @id @default(uuid())
  sessionId   String            @unique
  hostLogin   String
  floorNumber Int               @default(1)
  roomWidth   Int               @default(800)
  roomHeight  Int               @default(600)
  players     PlayerSaveState[]
  createdAt   DateTime          @default(now())
}

model PlayerSaveState {
  id             String          @id @default(uuid())
  runSaveId      String
  runSave        RunSave         @relation(fields: [runSaveId], references: [id], onDelete: Cascade)
  login          String
  archetype      String
  hp             Int
  maxHp          Int
  mana           Float
  maxMana        Int
  gold           Int
  weaponPresetId String
  inventory      InventoryItem[]
}

model InventoryItem {
  id                String          @id @default(uuid())
  playerSaveStateId String
  playerSaveState   PlayerSaveState @relation(fields: [playerSaveStateId], references: [id], onDelete: Cascade)
  itemId            String
  quantity          Int             @default(1)
}